# Server-side API base used by the BFF proxy (app/api/be) and /api/session.
# The browser never calls the API directly for REST — it goes through the BFF,
# which attaches the httpOnly auth cookie. Keep this server-only (no NEXT_PUBLIC).
API_BASE=http://localhost:8080/v1

# Still used client-side to derive the WebSocket URL for /ws/advisories (the
# advisories live feed connects directly; it requires no auth). Falls back as the
# BFF target too if API_BASE is unset.
NEXT_PUBLIC_API_BASE=http://localhost:8080/v1

# Cesium ion access token. Used by the /map and Map3DEditor views when you toggle
# the terrain source to "Cesium World Terrain". If unset, the admin falls back to
# the Kashmir Explorer project token committed in CesiumViewer.tsx (fine for
# local dev, but it shares rate limits across everyone running it).
# Get your own free token at https://ion.cesium.com → Access Tokens.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# MapTiler API key. Used by the /map and Map3DEditor views when you toggle
# the terrain source to "Premium" (MapTiler's terrain-rgb DEM + vector basemap).
# Premium quality, no rate-limit cliff like the free MapTiler tier warning.
# Get a free key at https://maptiler.com/cloud/ → Account → Keys.
# If unset, the Premium toggle renders a "set NEXT_PUBLIC_MAPTILER_KEY" hint
# and stays on AWS tiles.
NEXT_PUBLIC_MAPTILER_KEY=
